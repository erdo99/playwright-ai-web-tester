{
  "name": "ai-web-tester",
  "version": "1.1.0",
  "description": "AI-powered web app testing tool using Playwright",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run build && node dist/index.js",
    "test:run": "node dist/index.js",
    "test:all-apps": "npm run build && node dist/index.js --all-apps --cases valid",
    "dev": "tsc --watch"
  },
  "bin": {
    "ai-tester": "./dist/index.js"
  },
  "dependencies": {
    "playwright": "^1.44.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["playwright", "testing", "ai", "automation", "qa"],
  "author": "AI Web Tester",
  "license": "MIT"
}
